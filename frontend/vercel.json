{
  "rewrites": [
    { "source": "/website-design-hyderabad", "destination": "/website-design-hyderabad/index.html" },
    { "source": "/affordable-website-design-india", "destination": "/affordable-website-design-india/index.html" },
    { "source": "/ecommerce-website-development", "destination": "/ecommerce-website-development/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
